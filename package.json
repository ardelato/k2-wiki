{
  "name": "k2-wiki",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build && cp dist/index.html dist/404.html",
    "preview": "vite preview",
    "lint": "oxlint -c oxlintrc.json --vue-plugin",
    "lint:fix": "oxlint -c oxlintrc.json --vue-plugin --fix",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "prepare": "lefthook install"
  },
  "dependencies": {
    "@vueuse/core": "^14.2.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-vue-next": "^0.577.0",
    "tailwind-merge": "^3.5.0",
    "vue": "^3.5.13",
    "vue-router": "^4.5.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@vitejs/plugin-vue": "^5.2.3",
    "autoprefixer": "^10.4.27",
    "lefthook": "^2.1.4",
    "oxfmt": "^0.41.0",
    "oxlint": "^1.56.0",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.17",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "~5.7.2",
    "vite": "^6.2.0",
    "vue-tsc": "^2.2.0"
  }
}
